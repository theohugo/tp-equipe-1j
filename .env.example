# === LLM (une seule cle par equipe — ne jamais committer .env) ===
# Option 1 : Groq (recommande)
GROQ_API_KEY=gsk_VOTRE_CLE_ICI
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Option 2 : Google Gemini (alternative)
# GEMINI_API_KEY=VOTRE_CLE_ICI
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash

# === Vector store (projet A = qdrant) ===
VECTOR_STORE=qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=assistkb

# === Embeddings ===
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# === Chunking (R1 - a ajuster) ===
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# === Retrieval (R3 - a ajuster) ===
TOP_K=5
SIMILARITY_THRESHOLD=0.45

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
